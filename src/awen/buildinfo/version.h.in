#pragma once

namespace awen
{
    /// @brief The date-based version stamped when the package was built, `YYYY.MM.DD`.
    /// Regenerated by the awen-buildinfo-version step only when the date changes, so
    /// same-day rebuilds don't recompile BuildInfo.cpp.
    inline constexpr auto BuildVersion = "@AWEN_BUILD_VERSION@";
}
