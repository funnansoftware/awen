{
    "version": 7,
    "include": [
        "../compiler/emcc.json",
        "../config/binaryDir.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../target/web.json"
    ],
    "configurePresets": [
        {
            "name": "web",
            "displayName": "web (release build, emscripten)",
            "inherits": [
                "web-release"
            ]
        },
        {
            "name": "web-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-emcc",
                "target-web"
            ]
        },
        {
            "name": "web-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-emcc",
                "target-web"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "web",
            "configurePreset": "web"
        },
        {
            "name": "web-debug",
            "configurePreset": "web-debug"
        },
        {
            "name": "web-release",
            "configurePreset": "web-release"
        }
    ]
}
