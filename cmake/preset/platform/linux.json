{
    "version": 7,
    "include": [
        "../compiler/clang.json",
        "../compiler/gcc.json",
        "../config/binaryDir.json",
        "../config/coverage.json",
        "../config/debug.json",
        "../config/ninja.json",
        "../config/release.json",
        "../config/vcpkg.json",
        "../target/linux.json"
    ],
    "configurePresets": [
        {
            "name": "linux",
            "displayName": "linux (release build, GCC)",
            "inherits": [
                "linux-gcc-release"
            ]
        },
        {
            "name": "linux-gcc-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-gcc",
                "target-linux"
            ]
        },
        {
            "name": "linux-gcc-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-gcc",
                "target-linux"
            ]
        },
        {
            "name": "linux-clang-debug",
            "inherits": [
                "config-binaryDir",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-clang",
                "target-linux"
            ]
        },
        {
            "name": "linux-clang-release",
            "inherits": [
                "config-binaryDir",
                "config-release",
                "config-ninja",
                "config-vcpkg",
                "compiler-clang",
                "target-linux"
            ]
        },
        {
            "name": "linux-clang-coverage",
            "inherits": [
                "config-binaryDir",
                "config-coverage",
                "config-debug",
                "config-ninja",
                "config-vcpkg",
                "compiler-clang",
                "target-linux"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "linux",
            "configurePreset": "linux"
        },
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug"
        },
        {
            "name": "linux-gcc-release",
            "configurePreset": "linux-gcc-release"
        },
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug"
        },
        {
            "name": "linux-clang-release",
            "configurePreset": "linux-clang-release"
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage"
        }
    ],
    "testPresets": [
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release",
            "configurePreset": "linux-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-release",
            "configurePreset": "linux-clang-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
