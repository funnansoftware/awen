    "buildPresets": [
        {
            "name": "x64-linux-wasm-debug",
            "configurePreset": "x64-linux-wasm-debug"
        },
        {
            "name": "x64-linux-wasm-release",
            "configurePreset": "x64-linux-wasm-release"
        },
        {
            "name": "arm64-linux-wasm-debug",
            "configurePreset": "arm64-linux-wasm-debug"
        },
        {
            "name": "arm64-linux-wasm-release",
            "configurePreset": "arm64-linux-wasm-release"
