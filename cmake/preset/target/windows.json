{
    "version": 7,
    "configurePresets": [
        {
            "name": "target-windows",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "VCPKG_HOST_TRIPLET": "x64-windows",
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "target-windows-release",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "VCPKG_HOST_TRIPLET": "x64-windows-release",
                "VCPKG_TARGET_TRIPLET": "x64-windows-release"
            }
        }
    ]
}
